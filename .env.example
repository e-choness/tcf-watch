# Pick one notifier: telegram | pushover | console
TCF_NOTIFIER=telegram

# --- Telegram (free) ---
# 1. Message @BotFather -> /newbot -> copy the token
# 2. Message your new bot anything, then open:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    and copy "chat":{"id": ...}
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Pushover ($5 one-time after 30-day trial) ---
# User key: pushover.net dashboard. App token: create an application.
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=
# 1 = high (bypasses quiet hours on device settings), 2 = emergency (repeats until acked in app)
PUSHOVER_PRIORITY_HIGH=1

# --- Tuning ---
TCF_POLL_SECONDS=1800        # 30 min between polls (be polite to nonprofit sites)
TCF_RENOTIFY_SECONDS=900     # nag every 15 min while Dec-2026 keyword present & un-acked
TCF_FAIL_THRESHOLD=4         # alert after N consecutive fetch failures (~2h at 30-min polls)
TCF_HEARTBEAT_HOUR_UTC=15    # daily "still alive" message (15 UTC ≈ 9am Calgary)
